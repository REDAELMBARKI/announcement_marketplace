# --------------------------
# Node / NPM / frontend
# --------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dist/
build/

# --------------------------
# Laravel / PHP
# --------------------------
vendor/
.env                       # local environment config
.phpunit.result.cache
/storage/*.key
/storage/debugbar/*
/storage/logs/*.log
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*
/bootstrap/cache/*.php

# --------------------------
# Database files (SQLite)
# --------------------------
# Use ** so nested dirs (e.g. database/sqlite/*.db) are ignored, not only top-level *.db
backend/database/**/*.db
backend/database/**/*.db-shm
backend/database/**/*.db-wal
database/*.db
*.sqbpro
*.sqlite
*.sqlite3

frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.vite/

# --------------------------
# Vite / frontend caches (can grow large)
# --------------------------
.vite/
.cache/

# --------------------------
# Laravel public build artifacts (also in backend/.gitignore)
# --------------------------
backend/public/build/
backend/public/hot/
backend/public/storage/

# Accidental duplicate storage tree (should not be versioned)
backend/storage 2/

# --------------------------
# Local QA / screenshots (often large binaries)
# --------------------------
testing/


# --------------------------
# OS / Editor / IDE files
# --------------------------
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# --------------------------
# Optional: compiled / cache files
# --------------------------
*.class
*.pyc
*.pyo
*.log
